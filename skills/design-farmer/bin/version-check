#!/usr/bin/env bash

set -euo pipefail

SKILL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CACHE_DIR="${HOME}/.config/design-farmer"
CACHE_FILE="${CACHE_DIR}/version-check.cache"
REMOTE_URL="https://raw.githubusercontent.com/ohprettyhak/design-farmer/main/skills/design-farmer/SKILL.md"

TTL_OK=3600
TTL_UPGRADE=43200

LOCAL_VERSION=$(sed -n 's/^version:[[:space:]]*//p' "${SKILL_DIR}/SKILL.md" 2>/dev/null | head -1 | tr -d '[:space:]')
if [[ -z "$LOCAL_VERSION" ]] || [[ ! "$LOCAL_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  exit 0
fi

ver_gt() {
  local -a A B
  local i a b
  IFS='.' read -ra A <<< "$1"
  IFS='.' read -ra B <<< "$2"
  for i in 0 1 2; do
    a=${A[$i]:-0}
    b=${B[$i]:-0}
    if (( a > b )); then return 0; fi
    if (( a < b )); then return 1; fi
  done
  return 1
}

NOW=$(date +%s)
if [[ -f "$CACHE_FILE" ]]; then
  CACHE_TS=$(awk 'NR==1{print $1}' "$CACHE_FILE" 2>/dev/null || echo 0)
  CACHE_STATUS=$(awk 'NR==1{print $2}' "$CACHE_FILE" 2>/dev/null || echo "")
  CACHE_OLD=$(awk 'NR==1{print $3}' "$CACHE_FILE" 2>/dev/null || echo "")
  CACHE_NEW=$(awk 'NR==1{print $4}' "$CACHE_FILE" 2>/dev/null || echo "")
  ELAPSED=$(( NOW - CACHE_TS ))

  if [[ "$CACHE_STATUS" == "OK" ]] && [[ $ELAPSED -lt $TTL_OK ]] && [[ "$CACHE_OLD" == "$LOCAL_VERSION" ]]; then
    exit 0
  fi
  if [[ "$CACHE_STATUS" == "UPGRADE_AVAILABLE" ]] && [[ $ELAPSED -lt $TTL_UPGRADE ]] && [[ "$CACHE_OLD" == "$LOCAL_VERSION" ]]; then
    echo "UPGRADE_AVAILABLE ${CACHE_OLD} ${CACHE_NEW}"
    exit 0
  fi
fi

REMOTE_RAW=$(curl -fsSL --max-time 5 "$REMOTE_URL" 2>/dev/null || echo "")
REMOTE_VERSION=$(echo "$REMOTE_RAW" | sed -n 's/^version:[[:space:]]*//p' | head -1 | tr -d '[:space:]')

if [[ -z "$REMOTE_VERSION" ]] || [[ ! "$REMOTE_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  exit 0
fi

mkdir -p "$CACHE_DIR"

if ver_gt "$REMOTE_VERSION" "$LOCAL_VERSION"; then
  echo "${NOW} UPGRADE_AVAILABLE ${LOCAL_VERSION} ${REMOTE_VERSION}" > "$CACHE_FILE"
  echo "UPGRADE_AVAILABLE ${LOCAL_VERSION} ${REMOTE_VERSION}"
else
  echo "${NOW} OK ${LOCAL_VERSION}" > "$CACHE_FILE"
fi
